set shell := ["bash", "-c"]

# ┌─────────────────────────────────────────────────────────────────────┐
# │  Maple justfile                                                     │
# │                                                                     │
# │  From macOS:     just <recipe>                                      │
# │  From OrbStack:  mac just -f /Users/tony/Dev/OpenSecret/maple/native/justfile <recipe> │
# └─────────────────────────────────────────────────────────────────────┘

default:
  @just --list

# ── Helpers ──────────────────────────────────────────────────────────────────

nix_run := "nix develop --command bash -c"
ossl := 'PKG_CONFIG_PATH="$(brew --prefix openssl@3)/lib/pkgconfig" OPENSSL_DIR="$(brew --prefix openssl@3)"'

# ── Diagnostics ──────────────────────────────────────────────────────────────

# run rmp doctor
doctor:
  if command -v nix >/dev/null 2>&1; then \
    nix develop --command bash -c "if command -v rmp >/dev/null 2>&1; then rmp doctor; else cargo run --manifest-path rmp-cli/Cargo.toml -- doctor; fi"; \
  else \
    if command -v rmp >/dev/null 2>&1; then rmp doctor; else cargo run --manifest-path rmp-cli/Cargo.toml -- doctor; fi; \
  fi

# ── FFI Bindings ─────────────────────────────────────────────────────────────

# regenerate Swift FFI bindings (api_env: local|dev|prod)
bindings-swift api_env="local":
  if command -v nix >/dev/null 2>&1; then \
    nix develop --command bash -c "unset CC CXX AR RANLIB && if command -v rmp >/dev/null 2>&1; then rmp bindings swift; else cargo run --manifest-path rmp-cli/Cargo.toml -- bindings swift; fi"; \
  else \
    unset CC CXX AR RANLIB && if command -v rmp >/dev/null 2>&1; then rmp bindings swift; else cargo run --manifest-path rmp-cli/Cargo.toml -- bindings swift; fi; \
  fi

# regenerate Kotlin FFI bindings (api_env: local|dev|prod)
bindings-kotlin api_env="local":
  if command -v nix >/dev/null 2>&1; then \
    nix develop --command bash -c "unset CC CXX AR RANLIB && if command -v rmp >/dev/null 2>&1; then rmp bindings kotlin; else cargo run --manifest-path rmp-cli/Cargo.toml -- bindings kotlin; fi"; \
  else \
    unset CC CXX AR RANLIB && if command -v rmp >/dev/null 2>&1; then rmp bindings kotlin; else cargo run --manifest-path rmp-cli/Cargo.toml -- bindings kotlin; fi; \
  fi

# regenerate all FFI bindings (api_env: local|dev|prod)
bindings api_env="local":
  if command -v nix >/dev/null 2>&1; then \
    nix develop --command bash -c "unset CC CXX AR RANLIB && if command -v rmp >/dev/null 2>&1; then rmp bindings all; else cargo run --manifest-path rmp-cli/Cargo.toml -- bindings all; fi"; \
  else \
    unset CC CXX AR RANLIB && if command -v rmp >/dev/null 2>&1; then rmp bindings all; else cargo run --manifest-path rmp-cli/Cargo.toml -- bindings all; fi; \
  fi

# ── Desktop (iced) ───────────────────────────────────────────────────────────

# build desktop app only (api_env: local|dev|prod)
build-desktop api_env="local":
  api_env="{{api_env}}"; while [[ "$api_env" == api_env=* ]]; do api_env="${api_env#api_env=}"; done; \
  api_url="http://0.0.0.0:3000"; \
  if [ "$api_env" = "dev" ]; then api_url="https://enclave.secretgpt.ai"; elif [ "$api_env" = "prod" ]; then api_url="https://enclave.trymaple.ai"; fi; \
  {{ossl}} OPEN_SECRET_API_URL="$api_url" cargo build -p maple_desktop_iced

# build and run desktop app (api_env: local|dev|prod)
run-desktop api_env="local":
  api_env="{{api_env}}"; while [[ "$api_env" == api_env=* ]]; do api_env="${api_env#api_env=}"; done; \
  api_url="http://0.0.0.0:3000"; \
  if [ "$api_env" = "dev" ]; then api_url="https://enclave.secretgpt.ai"; elif [ "$api_env" = "prod" ]; then api_url="https://enclave.trymaple.ai"; fi; \
  {{ossl}} OPEN_SECRET_API_URL="$api_url" cargo run -p maple_desktop_iced

# ── iOS ──────────────────────────────────────────────────────────────────────

# build and launch iOS on simulator (api_env: local|dev|prod)
run-ios api_env="local":
  api_env="{{api_env}}"; while [[ "$api_env" == api_env=* ]]; do api_env="${api_env#api_env=}"; done; \
  api_url="http://0.0.0.0:3000"; \
  if [ "$api_env" = "dev" ]; then api_url="https://enclave.secretgpt.ai"; elif [ "$api_env" = "prod" ]; then api_url="https://enclave.trymaple.ai"; fi; \
  if command -v nix >/dev/null 2>&1; then \
    OPEN_SECRET_API_URL="$api_url" nix develop --command bash -c "unset CC CXX AR RANLIB && if command -v rmp >/dev/null 2>&1; then rmp run ios; else cargo run --manifest-path rmp-cli/Cargo.toml -- run ios; fi"; \
  else \
    unset CC CXX AR RANLIB && export OPEN_SECRET_API_URL="$api_url" && if command -v rmp >/dev/null 2>&1; then rmp run ios; else cargo run --manifest-path rmp-cli/Cargo.toml -- run ios; fi; \
  fi

# ── Android ──────────────────────────────────────────────────────────────────

# build and launch Android on emulator (api_env: local|dev|prod, pass serial=<id> to override)
run-android serial="emulator-5554" api_env="local":
  api_env="{{api_env}}"; while [[ "$api_env" == api_env=* ]]; do api_env="${api_env#api_env=}"; done; \
  api_url="http://0.0.0.0:3000"; \
  if [ "$api_env" = "dev" ]; then api_url="https://enclave.secretgpt.ai"; elif [ "$api_env" = "prod" ]; then api_url="https://enclave.trymaple.ai"; fi; \
  if command -v nix >/dev/null 2>&1; then \
    OPEN_SECRET_API_URL="$api_url" nix develop --command bash -c "unset CC CXX AR RANLIB && export PATH=\$HOME/.cargo/bin:\$PATH && if command -v rmp >/dev/null 2>&1; then rmp run android --serial {{serial}}; else cargo run --manifest-path rmp-cli/Cargo.toml -- run android --serial {{serial}}; fi"; \
  else \
    unset CC CXX AR RANLIB && export PATH=\$HOME/.cargo/bin:\$PATH && export OPEN_SECRET_API_URL="$api_url" && if command -v rmp >/dev/null 2>&1; then rmp run android --serial {{serial}}; else cargo run --manifest-path rmp-cli/Cargo.toml -- run android --serial {{serial}}; fi; \
  fi

# build Android APK only (api_env: local|dev|prod)
build-android api_env="local":
  api_env="{{api_env}}"; while [[ "$api_env" == api_env=* ]]; do api_env="${api_env#api_env=}"; done; \
  api_url="http://0.0.0.0:3000"; \
  if [ "$api_env" = "dev" ]; then api_url="https://enclave.secretgpt.ai"; elif [ "$api_env" = "prod" ]; then api_url="https://enclave.trymaple.ai"; fi; \
  cd android && OPEN_SECRET_API_URL="$api_url" ./gradlew assembleDebug

# ── Convenience ──────────────────────────────────────────────────────────────

# build all platforms (no launch)
build-all api_env="local":
  just build-desktop "{{api_env}}"
  just build-android "{{api_env}}"
  @echo "Desktop and Android built. iOS is build+run only via rmp."

# rebuild FFI bindings, then launch all platforms
run-all serial="emulator-5554" api_env="local":
  just bindings "{{api_env}}"
  just run-ios "{{api_env}}"
  just run-android serial={{serial}} "{{api_env}}"
  just run-desktop "{{api_env}}"
